# .env.development
# 개발 환경에서는 Vite dev server가 /api 요청을 백엔드로 proxy합니다.
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# .env.production
# 운영 환경에서 백엔드가 같은 도메인의 /api에 있으면 비워둡니다.
# 백엔드가 별도 도메인이라면 VITE_API_BASE_URL=https://api.example.com 형태로 지정합니다.
# VITE_API_BASE_URL=
# VITE_API_PROXY_TARGET=
